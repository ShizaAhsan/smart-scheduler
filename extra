<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard</title>
    <link rel="stylesheet" href="../css/style.css">
    <link rel="stylesheet" href="../css/dashboard.css">
</head>
<body>

<div class="dashboard-wrap">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sb-brand">🎓 Campus Scheduler</div>
        <nav class="sb-nav">
            <a href="dashboard.html" class="sb-item active">🏠 Dashboard</a>
            <a href="timetable.html" class="sb-item">📅 My Timetable</a>
            <a href="courses.html" class="sb-item">📚 Courses</a>
            <a href="announcements.html" class="sb-item">🔔 Announcements</a>
            <a href="profile.html" class="sb-item">👤 Profile</a>
            <a href="settings.html" class="sb-item">⚙️ Settings</a>
        </nav>
        <a href="../login.html" class="sb-item sb-logout">🚪 Logout</a>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">

        <!-- TOP BAR -->
        <div class="topbar">
            <div class="topbar-title">Dashboard</div>
            <div class="topbar-right">
                <span class="bell">🔔</span>
                <div class="avatar">AR</div>
                <span class="username">Ali Raza ▾</span>
            </div>
        </div>

        <!-- PAGE CONTENT -->
        <div class="page-content">

            <!-- WELCOME -->
            <div class="welcome-section">
                <h2>Welcome back, Ali! 👋</h2>
                <p>Here's what's happening today.</p>
            </div>

            <!-- STATS -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-num blue">5</div>
                    <div class="stat-label">Courses</div>
                </div>
                <div class="stat-card">
                    <div class="stat-num orange">2</div>
                    <div class="stat-label">Assignments</div>
                </div>
                <div class="stat-card">
                    <div class="stat-num red">2</div>
                    <div class="stat-label">Exams</div>
                </div>
                <div class="stat-card">
                    <div class="stat-num green">3</div>
                    <div class="stat-label">Announcements</div>
                </div>
            </div>

            <!-- TWO COLUMNS -->
            <div class="two-col">

                <!-- TODAY'S CLASSES -->
                <div class="card">
                    <h3 class="card-title">Today's Classes</h3>

                    <div class="class-item">
                        <span class="dot blue"></span>
                        <div class="class-info">
                            <div class="class-name">Data Structures</div>
                            <div class="class-sub">Room CS-301 · Sir Ali</div>
                        </div>
                        <div class="class-time">9:00 AM</div>
                    </div>

                    <div class="class-item">
                        <span class="dot green"></span>
                        <div class="class-info">
                            <div class="class-name">Database Systems</div>
                            <div class="class-sub">Room CS-302 · Sir Farhan</div>
                        </div>
                        <div class="class-time">11:00 AM</div>
                    </div>

                    <div class="class-item">
                        <span class="dot purple"></span>
                        <div class="class-info">
                            <div class="class-name">Web Engineering</div>
                            <div class="class-sub">CS Lab 1 · Sir Hamza</div>
                        </div>
                        <div class="class-time">2:00 PM</div>
                    </div>

                </div>

                <!-- UPCOMING EVENTS -->
                <div class="card">
                    <h3 class="card-title">Upcoming Events</h3>

                    <div class="event-item">
                        <div class="event-title">
                            Quiz — DSA
                            <span class="badge red">Exam</span>
                        </div>
                        <div class="event-date">24 May 2024</div>
                    </div>

                    <div class="event-item">
                        <div class="event-title">
                            Mid Term Exams
                            <span class="badge red">Exam</span>
                        </div>
                        <div class="event-date">10 June 2024</div>
                    </div>

                    <div class="event-item">
                        <div class="event-title">
                            Project Submission
                            <span class="badge amber">Task</span>
                        </div>
                        <div class="event-date">20 June 2024</div>
                    </div>

                    <div class="event-item">
                        <div class="event-title">
                            Lab Evaluation
                            <span class="badge blue">Lab</span>
                        </div>
                        <div class="event-date">25 June 2024</div>
                    </div>

                </div>

            </div>
            <!-- end two-col -->

        </div>
        <!-- end page-content -->

    </div>
    <!-- end main-content -->

</div>
<!-- end dashboard-wrap -->

<script src="../js/student.js"></script>
</body>
</html>